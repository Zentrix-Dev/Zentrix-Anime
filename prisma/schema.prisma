// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// NextAuth Core Models
// ==========================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id               String             @id @default(cuid())
  name             String?
  email            String?            @unique
  emailVerified    DateTime?
  image            String?
  password         String?            // Required for Credentials (Email/Password) login
  accounts         Account[]
  sessions         Session[]
  
  // Custom Relations
  continueWatching ContinueWatching[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ==========================================
// ZentrixAnime Custom Models
// ==========================================

model ContinueWatching {
  id        String   @id @default(cuid())
  userId    String
  animeId   Int      // Storing the AniList ID
  episode   Int      // The episode number they are currently on
  timestamp Int      // (Optional) Video player timestamp in seconds, defaults to 0
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt // Automatically updates when they watch a new episode

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Ensure a user only has one active record per anime so the database doesn't clutter
  @@unique([userId, animeId])
}
